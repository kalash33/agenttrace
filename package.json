{
  "name": "@hackerx333/agenttrace",
  "version": "1.0.2",
  "description": "The open-source accountability layer for AI agents. Trace every action. Explain every decision. Control what matters.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "agenttrace": "./bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "AGENTTRACE_INTEGRATION=true vitest run --reporter=verbose",
    "test:unit": "vitest run tests/unit",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "ai-agents",
    "accountability",
    "explainability",
    "guardrails",
    "audit-trail",
    "langchain",
    "openai",
    "anthropic",
    "agent-safety",
    "llm",
    "typescript",
    "agenttrace"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalash33/agenttrace.git"
  },
  "homepage": "https://github.com/kalash33/agenttrace#readme",
  "bugs": {
    "url": "https://github.com/kalash33/agenttrace/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "openai": "^4.52.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "bin",
    "agenttrace-ui/dist",
    "README.md",
    "LICENSE"
  ]
}
